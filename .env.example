# Required: endpoint returning live market rows.
# Expected response shape: JSON array OR { data: [...] } OR { markets: [...] }.
VITE_MARKET_DATA_URL=

# Optional auth for provider/gateway.
VITE_MARKET_DATA_API_KEY=

# Optional poll interval in milliseconds.
VITE_MARKET_DATA_POLL_MS=15000

# Optional risk/profile settings.
VITE_DAILY_TARGET_USD=500
VITE_MAX_DAILY_LOSS_USD=200
VITE_PER_TRADE_RISK_USD=50
VITE_MAKER_FEE_PER_CONTRACT=0.02
VITE_TAKER_FEE_PER_CONTRACT=0.03
VITE_SLIPPAGE_PER_CONTRACT=0.01
VITE_PAPER_BUYING_POWER_USD=5000
